OPENROUTE_SERVICE_API_KEY=your_openrouteservice_api_key
OPENCAGE_API_KEY=your_opencage_api_key
GOOGLE_PLACES_API_KEY=your_server_side_google_places_api_key
# Exact parent origin allowed to receive the sanitized V2 context bridge when /v2 is embedded.
VITE_MAPGAP_V3_HOST_ORIGIN=https://mapgap-v3-preview.netlify.app
# Optional typed POI provider override. Dog-park searches default to the public Overpass endpoint.
OVERPASS_API_URL=https://maps.mail.ru/osm/tools/overpass/api/interpreter
# Local Valhalla dev only. Production needs a hosted Valhalla URL reachable from Netlify.
VALHALLA_BASE_URL=http://localhost:8002
VALHALLA_SHARED_SECRET=use_a_long_random_server_to_server_secret
VALHALLA_REQUIRE_CLIENT_SECRET=false
VALHALLA_COVERAGE_REGION=ny-nj
VALHALLA_COVERAGE_LABEL=New York + New Jersey Valhalla graph
