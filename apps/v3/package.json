{
  "name": "mapgap-v3",
  "private": true,
  "version": "3.0.0-alpha.2",
  "type": "module",
  "description": "Dependency-isolated MapGap V3 host: the real V2 alongside a purpose-built location-intelligence workbench.",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:contract && npm run test:smoke && npm run test:security",
    "test:contract": "playwright test -c playwright.config.ts tests/project-contract.spec.ts tests/project-to-datasets.spec.ts tests/analysis-to-datasets.spec.ts tests/scale.spec.ts tests/intelligence-layer-factories.spec.ts tests/v2-context-host.spec.ts",
    "test:smoke": "playwright test -c playwright.config.ts tests/v3-alpha.spec.ts",
    "test:security": "playwright test -c playwright.config.ts tests/security.spec.ts",
    "test:scale": "playwright test -c playwright.config.ts tests/scale.spec.ts",
    "check:boundary": "node scripts/check-deployment-policy.mjs",
    "check:budget": "node scripts/check-artifact-budget.mjs",
    "audit:alpha": "node scripts/check-audit-dispositions.mjs",
    "production:gate": "node scripts/check-production-gate.mjs",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "9.3.6",
    "@deck.gl/core": "9.3.6",
    "@deck.gl/layers": "9.3.6",
    "@deck.gl/mapbox": "9.3.6",
    "@mapgap/project-contract": "file:../../packages/project-contract",
    "h3-js": "4.5.0",
    "maplibre-gl": "5.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "postcss": "8.5.10",
    "thrift": "0.23.0",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/geojson": "7946.0.16",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "5.7.2",
    "vite": "8.0.16"
  }
}
