{
  "name": "mapgap-v3",
  "private": true,
  "version": "3.0.0-alpha.1",
  "type": "module",
  "description": "Dependency-isolated MapGap V3 analyst prerelease backed by the public MapGap Kepler fork.",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:contract && npm run test:smoke && npm run test:security",
    "test:contract": "playwright test -c playwright.config.ts tests/project-contract.spec.ts tests/project-to-datasets.spec.ts tests/analysis-to-datasets.spec.ts tests/comparison-config.spec.ts tests/comparison-runtime.spec.ts tests/scale.spec.ts",
    "test:smoke": "playwright test -c playwright.config.ts tests/v3-alpha.spec.ts",
    "test:security": "playwright test -c playwright.config.ts tests/security.spec.ts",
    "test:scale": "playwright test -c playwright.config.ts tests/scale.spec.ts",
    "check:boundary": "node scripts/check-deployment-policy.mjs",
    "audit:alpha": "node scripts/check-audit-dispositions.mjs",
    "production:gate": "node scripts/check-production-gate.mjs",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "9.3.6",
    "@deck.gl/core": "9.3.6",
    "@deck.gl/extensions": "9.3.6",
    "@deck.gl/geo-layers": "9.3.6",
    "@deck.gl/layers": "9.3.6",
    "@deck.gl/mapbox": "9.3.6",
    "@deck.gl/mesh-layers": "9.3.6",
    "@deck.gl/react": "9.3.6",
    "@deck.gl/widgets": "9.3.6",
    "@hubble.gl/react": "https://github.com/evcatalyst/hubble.gl/releases/download/mapgap-v3.0.0-alpha.1/hubble-react.tgz",
    "@kepler.gl/actions": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/actions.tgz",
    "@kepler.gl/cloud-providers": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/cloud-providers.tgz",
    "@kepler.gl/common-utils": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/common-utils.tgz",
    "@kepler.gl/components": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/components-esm.tgz",
    "@kepler.gl/constants": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/constants.tgz",
    "@kepler.gl/deckgl-arrow-layers": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/deckgl-arrow-layers.tgz",
    "@kepler.gl/deckgl-layers": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/deckgl-layers.tgz",
    "@kepler.gl/effects": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/effects.tgz",
    "@kepler.gl/layers": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/layers.tgz",
    "@kepler.gl/localization": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/localization.tgz",
    "@kepler.gl/processors": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/processors.tgz",
    "@kepler.gl/reducers": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/reducers.tgz",
    "@kepler.gl/schemas": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/schemas.tgz",
    "@kepler.gl/styles": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/styles.tgz",
    "@kepler.gl/table": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/table.tgz",
    "@kepler.gl/task-runtime": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/task-runtime.tgz",
    "@kepler.gl/tasks": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/tasks.tgz",
    "@kepler.gl/types": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/types.tgz",
    "@kepler.gl/utils": "https://github.com/evcatalyst/kepler.gl/releases/download/mapgap-v3.0.0-alpha.1/utils.tgz",
    "@mapgap/project-contract": "file:../../packages/project-contract",
    "@luma.gl/core": "9.3.6",
    "@luma.gl/engine": "9.3.6",
    "@luma.gl/shadertools": "9.3.6",
    "@luma.gl/webgl": "9.3.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-redux": "9.2.0",
    "redux": "5.0.1",
    "styled-components": "6.4.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "styled-components": "6.4.3",
    "thrift": "0.23.0",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "5.7.2",
    "vite": "8.0.16"
  }
}
