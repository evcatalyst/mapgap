index 0000000..fcd44a7
--- /dev/null
+++ b/src/task-runtime/src/index.ts
@@ -0,0 +1,256 @@
+// SPDX-License-Identifier: MIT
+// Copyright contributors to the kepler.gl project
+
+type Continuation = (value: any) => any;
+type Context = {onProgress: Continuation};
+type Effector = (success: Continuation, error: Continuation, context?: Context) => any;
+type RunEffect = (
+  effect: Effector & {payload?: any; type?: string},
+  success: Continuation,
+  error: Continuation,
+  context?: Context
+) => any;
+
+export type TaskInstance = {
+  label: string;
+  type: string;
+  payload: any;
+  run: (runEffect: RunEffect, success: Continuation, error: Continuation, context?: Context) => any;
+  map: (successTransform: Continuation) => TaskInstance;
+  bimap: (successTransform: Continuation, errorTransform: Continuation) => TaskInstance;
+  chain: (chainTransform: (value: any) => TaskInstance) => TaskInstance;
+};
+
+type TaskCreator = ((outbound: any) => TaskInstance) & {type: string};
+type Reporter = (event: 'start' | 'success' | 'error', task: TaskInstance, payload: any) => void;
+
+let reportEffects: Reporter = () => {};
+
+export function reportTasksForTesting(reporter: Reporter): void {
+  reportEffects = reporter;
+}
+
+function createTask(
+  payload: any,
+  next: TaskInstance['run'],
+  label: string
+): TaskInstance {
+  const task: TaskInstance = {
+    label,
+    type: label,
+    payload,
+    run: next,
+    map(successTransform) {
+      return createTask(
+        payload,
+        (runEffect, success, error, context) =>
+          next(runEffect, result => success(successTransform(result)), error, context),
+        label
+      );
+    },
+    bimap(successTransform, errorTransform) {
+      return createTask(
+        payload,
+        (runEffect, success, error, context) =>
+          next(
+            runEffect,
+            result => success(successTransform(result)),
+            reason => error(errorTransform(reason)),
+            context
+          ),
+        label
+      );
+    },
+    chain(chainTransform) {
+      return createTask(
+        payload,
+        (runEffect, success, error, context) =>
+          next(
+            runEffect,
+            result => chainTransform(result).run(runEffect, success, error, context),
+            error,
+            context
+          ),
+        `Chain(${label})`
+      );
+    }
+  };
+  return task;
+}
+
+function createInstrumentedTask(effector: Effector, payload: any, label: string): TaskInstance {
+  let task: TaskInstance;
+  const instrumented = Object.assign(
+    (success: Continuation, error: Continuation, context?: Context) => {
+      reportEffects('start', task, payload);
+      return effector(
+        result => {
+          reportEffects('success', task, result);
+          return success(result);
+        },
+        reason => {
+          reportEffects('error', task, reason);
+          return error(reason);
+        },
+        context
+      );
+    },
+    {payload, type: label}
+  );
+  task = createTask(
+    payload,
+    (runEffect, success, error, context) => runEffect(instrumented, success, error, context),
+    label
+  );
+  return task;
+}
+
+export function fromPromise(fn: (arg: any) => Promise<any>, label: string): TaskCreator {
+  return Object.assign(
+    (outbound: any) => createInstrumentedTask((success, error) => fn(outbound).then(success, error), outbound, label),
+    {type: label}
+  );
+}
+
+export function fromPromiseWithProgress(fn: (input: any) => Promise<any>, label: string): TaskCreator {
+  return Object.assign(
+    ({arg, onProgress}: any) =>
+      createInstrumentedTask(
+        (success, error, context) =>
+          fn({
+            arg,
+            onProgress: context ? (value: any) => context.onProgress(onProgress(value)) : () => {}
+          }).then(success, error),
+        {arg, onProgress},
+        label
+      ),
+    {type: label}
+  );
+}
+
+export function fromCallback(
+  fn: (arg: any, callback: (error: any, result: any) => any) => any,
+  label: string
+): TaskCreator {
+  return Object.assign(
+    (outbound: any) =>
+      createInstrumentedTask(
+        (success, error) => fn(outbound, (err: any, result: any) => (err ? error(err) : success(result))),
+        outbound,
+        label
+      ),
+    {type: label}
+  );
+}
+
+export function taskCreator(fn: Function, label: string): TaskCreator {
+  return Object.assign(
+    (outbound: any) =>
+      createInstrumentedTask((success, error) => fn(outbound, success, error), outbound, label),
+    {type: label}
+  );
+}
+
+function taskGroup(tasks: TaskInstance[], settle: boolean): TaskInstance {
+  const label = `Task.${settle ? 'allSettled' : 'all'}(${tasks.map(task => task.type).join(', ')})`;
+  return createTask(
+    tasks.map(task => task.payload),
+    (runEffect, success, error, context) => {
+      if (!tasks.length) return success([]);
+      const values = Array(tasks.length);
+      let complete = 0;
+      let failed = false;
+      const finish = (index: number, status: 'fulfilled' | 'rejected') => (value: any) => {
+        if (failed) return undefined;
+        if (!settle && status === 'rejected') {
+          failed = true;
+          return error(value);
+        }
+        values[index] = settle ? {status, value} : value;
+        complete += 1;
+        return complete === tasks.length ? success(values) : undefined;
+      };
+      return Promise.allSettled(
+        tasks.map((task, index) =>
+          task.run(runEffect, finish(index, 'fulfilled'), finish(index, 'rejected'), context)
+        )
+      );
+    },
+    label
+  );
+}
+
+export const all = (tasks: TaskInstance[]) => taskGroup(tasks, false);
+export const allSettled = (tasks: TaskInstance[]) => taskGroup(tasks, true);
+
+const GLOBAL_KEY = '___GLOBAL_TASK_STATE_e3b0c442';
+const root = globalThis as typeof globalThis & Record<string, any>;
+root[GLOBAL_KEY] ||= {tasks: [], lastWithTaskCall: null};
+
+export const getGlobalTaskQueue = (): TaskInstance[] => root[GLOBAL_KEY].tasks;
+const updateGlobalTaskQueue = (tasks: TaskInstance[]) => {
+  root[GLOBAL_KEY].tasks = tasks;
+};
+
+let stackCaptureEnabled = true;
+
+export function withTasks<State>(state: State, tasks: TaskInstance | TaskInstance[]): State {
+  if (stackCaptureEnabled && !root[GLOBAL_KEY].lastWithTaskCall) {
+    root[GLOBAL_KEY].lastWithTaskCall = new Error('Tasks should not be added outside of reducers.');
+  }
+  updateGlobalTaskQueue(getGlobalTaskQueue().concat(Array.isArray(tasks) ? tasks : [tasks]));
+  return state;
+}
+
+export const withTask = withTasks;
+export const disableStackCapturing = () => {
+  stackCaptureEnabled = false;
+};
+
+const resolved = Promise.resolve();
+export const taskMiddleware = (store: any) => (next: any) => (action: any) => {
+  if (stackCaptureEnabled && getGlobalTaskQueue().length) {
+    const error = root[GLOBAL_KEY].lastWithTaskCall;
+    root[GLOBAL_KEY].lastWithTaskCall = null;
+    throw error;
+  }
+  next(action);
+  const dispatch = (nextAction: any) => resolved.then(() => store.dispatch(nextAction));
+  const tasks = getGlobalTaskQueue();
+  if (!tasks.length) return resolved;
+  updateGlobalTaskQueue([]);
+  root[GLOBAL_KEY].lastWithTaskCall = null;
+  return Promise.all(
+    tasks.map(task => task.run((effect, success, error, context) => effect(success, error, context), dispatch, dispatch, {onProgress: dispatch}))
+  );
+};
+
+function capture(task: TaskInstance, simulator: RunEffect): any {
+  let returned: any;
+  task.run(simulator, value => (returned = value), value => (returned = value));
+  if (typeof returned === 'undefined') throw new Error('A success or error handler was never called!');
+  return returned;
+}
+
+export const succeedTaskInTest = (task: TaskInstance, value: any) =>
+  capture(task, (_effect, success) => success(value));
+export const errorTaskInTest = (task: TaskInstance, value: any) =>
+  capture(task, (_effect, _success, error) => error(value));
+export const simulateTask = (task: TaskInstance, simulator: RunEffect) => capture(task, simulator);
+export const succeedTaskWithValues = (task: TaskInstance, values: any[]) => {
+  let index = 0;
+  return capture(task, (_effect, success) => {
+    if (index >= values.length) throw new Error('Not enough values were provided!');
+    return success(values[index++]);
+  });
+};
+export const drainTasksForTesting = (): TaskInstance[] => {
+  const tasks = getGlobalTaskQueue();
+  updateGlobalTaskQueue([]);
+  root[GLOBAL_KEY].lastWithTaskCall = null;
+  return tasks;
+};
+
+const Task = {all, allSettled, fromCallback, fromPromise, fromPromiseWithProgress};
+export {Task};
+export default Task;

